{
  "_doc": "Copy to ~/.grafel/embeddings.json. Env vars (GRAFEL_EMBEDDING_BACKEND, _URL, _MODEL, _API_KEY, _DIMS) override every field below. See ADR-0019.",
  "_examples": {
    "default": { "backend": "builtin" },
    "ollama": {
      "backend": "http",
      "http": {
        "url": "http://localhost:11434/v1",
        "model": "nomic-embed-text",
        "dims": 768
      }
    },
    "openai": {
      "backend": "http",
      "http": {
        "url": "https://api.openai.com/v1",
        "model": "text-embedding-3-small",
        "api_key": "sk-...",
        "dims": 1536
      }
    },
    "bm25_only": { "backend": "disabled" }
  },
  "backend": "builtin"
}
