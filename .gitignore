# Build artifacts
/dist/
/build/
# Dashboard SPA build outputs — generated by `make dashboard-build`, not source.
# A committed PLACEHOLDER.md lives in internal/dashboard/dist/ so `//go:embed
# dist` in static.go has at least one file on a fresh checkout (otherwise
# `go build ./...` fails before `make dashboard-build` has been run).
/webui-v2/dist/
/internal/dashboard/dist/*
!/internal/dashboard/dist/PLACEHOLDER.md
*.exe
*.dll
*.so
*.dylib
/grafel
/grafel-*

# Test
*.test
*.out
coverage.out
coverage.html

# Environment
.env
.env.local

# IDE
.idea/
.vscode/
.DS_Store
*.swp

# Worktrees (linked checkouts used for feature isolation)
.worktrees/
.claude/worktrees/

# Local-only planning files
BACKLOG.md
SCRATCH.md

# Local-only verification reports (may reference private corpora)
/docs/verification/
/reports/
/.verify/

# Go module cache
# vendor/ was previously kept for the #1796 iter.go CGO patch workaround.
# MinGW on Windows CI (CGO_ENABLED=1) makes the patch unnecessary — dropped in #2230.
/vendor/

# grafel index output
.grafel/
graph.json
graph.fb
graph-stats.json

# Exception: golden fixtures need committed group.json manifests for smoke tests
!/internal/quality/golden/**/.grafel/group.json

# Root-level images — PR review screenshots accidentally committed (#cleanup)
# Legitimate design assets go under docs/mockups/ or docs/screenshots/.
/*.png
/*.jpg
/*.jpeg
/*.gif
/*.webp
# Catch the screenshots-<number>/ folder pattern at root
/screenshots-*/
# Catch design-handoff-* one-off folders at root
/design-handoff-*/

# Catch shell-redirect typos that create literal --flag files at repo root
/--*

# Catch tilde redirect typos (literal `~` directory)
/~/

# External worktrees should be siblings of the repo, not nested inside it
/grafel-worktrees/
/.grafel/
